#!/usr/bin/env janet

(defn- dirname
  [path]
  (var i (- (length path) 1))
  (while (and (>= i 0) (not= (get path i) (chr "/")))
    (-- i))
  (if (< i 0) "." (string/slice path 0 i)))

(def script-path (os/realpath (dyn :current-file)))
(def root (dirname (dirname script-path)))
(def source-launcher (string root "/lib/launcher.janet"))

(def launcher
  (if (= :file (os/stat source-launcher :mode))
    (require "../lib/launcher")
    (do
      (setdyn :syspath root)
      (require "otter/lib/launcher"))))

(apply (module/value launcher 'run) (array/slice (dyn :args) 1))
